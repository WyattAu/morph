#!/usr/bin/env bash
# Pre-commit hook for Morph monorepo
# Enforces Lean 4 compilation, sorry scanning, and Python spec-tools tests.
#
# Install: cp .githooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit

set -euo pipefail

echo "========================================="
echo " Morph Pre-Commit Check"
echo "========================================="
echo ""

FAILURES=0

# Step 1: Lake build (compile all Lean 4 sources)
echo "[1/4] Running lake build Morph..."
BUILD_START=$(date +%s)

if lake build Morph 2>&1 | tee /tmp/morph_precommit_build.log; then
    BUILD_END=$(date +%s)
    BUILD_SECS=$((BUILD_END - BUILD_START))
    echo ""
    echo "[1/4] Lake build PASSED (${BUILD_SECS}s)"
else
    ERR_COUNT=$(grep -c "^error:" /tmp/morph_precommit_build.log 2>/dev/null || echo "unknown")
    echo ""
    echo "[1/4] Lake build FAILED (${ERR_COUNT} errors)"
    echo ""
    echo "First 10 errors:"
    grep "^error:" /tmp/morph_precommit_build.log | head -10
    echo ""
    echo "Commit blocked. Fix the errors above before committing."
    exit 1
fi

# Step 2: Check for sorry declarations (formal verification gaps)
echo ""
echo "[2/4] Checking for 'sorry' declarations..."

SORRY_COUNT=$(grep -r "sorry" Morph/ --include="*.lean" 2>/dev/null | grep -v "\.olean" | grep -v "/--" | wc -l || true)
SORRY_FILES=$(grep -rl "sorry" Morph/ --include="*.lean" 2>/dev/null | grep -v "\.olean" | wc -l || true)

if [ "$SORRY_COUNT" -gt 0 ]; then
    echo "[2/4] WARNING: Found ${SORRY_COUNT} 'sorry' declarations in ${SORRY_FILES} files."
    echo "       These represent gaps in formal verification."
    echo "       Listing affected files:"
    grep -rn "sorry" Morph/ --include="*.lean" 2>/dev/null | grep -v "\.olean" | grep -v "/--" | head -20
    echo ""
    echo "Commit allowed (warnings only). Consider fixing 'sorry' declarations."
else
    echo "[2/4] No 'sorry' declarations found."
fi

# Step 3: Lake build Morph.Tests
echo ""
echo "[3/4] Running lake build Morph.Tests..."

if lake build Morph.Tests 2>&1 | tee /tmp/morph_precommit_tests_build.log; then
    echo ""
    echo "[3/4] Morph.Tests build PASSED"
else
    echo ""
    echo "[3/4] Morph.Tests build FAILED"
    echo ""
    echo "First 10 errors:"
    grep "^error:" /tmp/morph_precommit_tests_build.log | head -10
    echo ""
    echo "Commit blocked. Fix the test compilation errors above."
    exit 1
fi

# Step 4: Python spec-tools tests (if venv and spec-tools are available)
echo ""
echo "[4/4] Running Python spec-tools tests..."

# Try to find spec-tools: check project venv, then system
SPEC_TOOLS_PYTEST=""
if [ -f ".venv/bin/pytest" ] && [ -d ".venv/lib" ]; then
    SPEC_TOOLS_PYTEST=".venv/bin/pytest"
elif command -v pytest &>/dev/null && python3 -c "import spec_tools" 2>/dev/null; then
    SPEC_TOOLS_PYTEST="pytest"
fi

if [ -n "$SPEC_TOOLS_PYTEST" ]; then
    if $SPEC_TOOLS_PYTEST scripts/tests/ --tb=short -q 2>&1 | tee /tmp/morph_precommit_pytest.log; then
        echo ""
        echo "[4/4] Python spec-tools tests PASSED"
    else
        echo ""
        echo "[4/4] Python spec-tools tests FAILED"
        echo ""
        echo "Commit blocked. Fix the failing Python tests above."
        echo "Tip: Activate the venv with 'source .venv/bin/activate' and run"
        echo "     'pytest scripts/tests/' to debug failures."
        exit 1
    fi
else
    echo "[4/4] Python spec-tools not found (skipped)."
    echo "       To enable: pip install -e scripts/ in a virtual environment."
fi

echo ""
echo "========================================="
echo " Pre-commit checks PASSED"
echo "========================================="
echo ""
exit 0
