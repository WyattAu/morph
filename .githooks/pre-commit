#!/usr/bin/env bash
# Pre-commit hook for Morph monorepo
# Enforces: Lean 4 compilation, sorry scanning, Python spec-tools tests,
#           ruff lint, ruff format, mypy type-check, and stub detection.
#
# Install: cp .githooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit

set -euo pipefail

echo "========================================="
echo " Morph Pre-Commit Check"
echo "========================================="
echo ""

# Step 1: Lake build (compile all Lean 4 sources)
echo "[1/7] Running lake build Morph..."
BUILD_START=$(date +%s)
BUILD_LOG=$(mktemp /tmp/morph_precommit_build_XXXXXX.log)

if lake build Morph 2>&1 | tee "$BUILD_LOG"; then
    BUILD_END=$(date +%s)
    BUILD_SECS=$((BUILD_END - BUILD_START))
    echo ""
    echo "[1/7] Lake build PASSED (${BUILD_SECS}s)"
else
    ERR_COUNT=$(grep -c "^error:" /tmp/morph_precommit_build.log 2>/dev/null || echo "unknown")
    echo ""
    echo "[1/7] Lake build FAILED (${ERR_COUNT} errors)"
    echo ""
    echo "First 10 errors:"
    grep "^error:" "$BUILD_LOG" | head -10
    echo ""
    echo "Commit blocked. Fix the errors above before committing."
    rm -f "$BUILD_LOG"
    exit 1
fi
rm -f "$BUILD_LOG"

# Step 2: Check for sorry declarations (formal verification gaps)
echo ""
echo "[2/7] Checking for 'sorry' declarations..."

SORRY_COUNT=$(grep -rn "sorry" Morph/ --include="*.lean" 2>/dev/null | grep -v "^\s*--" | wc -l || true)
SORRY_FILES=$(grep -rl "sorry" Morph/ --include="*.lean" 2>/dev/null | wc -l || true)

if [ "$SORRY_COUNT" -gt 0 ]; then
    echo "[2/7] WARNING: Found ${SORRY_COUNT} 'sorry' declarations in ${SORRY_FILES} files."
    echo "       These represent gaps in formal verification."
    echo "       Listing affected files:"
    grep -rn "sorry" Morph/ --include="*.lean" 2>/dev/null | grep -v "^\s*--" | head -20
    echo ""
    echo "Commit allowed (warnings only). Consider fixing 'sorry' declarations."
else
    echo "[2/7] No 'sorry' declarations found."
fi

# Step 3: Check for spec stubs
echo ""
echo "[3/7] Checking for spec stubs (example : True := trivial)..."

STUB_COUNT=$(grep -r "example : True := trivial" Morph/Specs/ --include="*.lean" 2>/dev/null | wc -l || true)

if [ "$STUB_COUNT" -gt 0 ]; then
    echo "[3/7] WARNING: Found ${STUB_COUNT} spec stubs in Morph/Specs/."
    echo "       These should be replaced with real proofs."
    echo "       Commit allowed (warnings only)."
else
    echo "[3/7] No spec stubs found."
fi

# Step 4: Lake build Morph.Tests
echo ""
echo "[4/7] Running lake build Morph.Tests..."
TESTS_LOG=$(mktemp /tmp/morph_precommit_tests_XXXXXX.log)

if lake build Morph.Tests 2>&1 | tee "$TESTS_LOG"; then
    echo ""
    echo "[4/7] Morph.Tests build PASSED"
else
    echo ""
    echo "[4/7] Morph.Tests build FAILED"
    echo ""
    echo "First 10 errors:"
    grep "^error:" "$TESTS_LOG" | head -10
    echo ""
    echo "Commit blocked. Fix the test compilation errors above."
    rm -f "$TESTS_LOG"
    exit 1
fi
rm -f "$TESTS_LOG"

# Step 5: Python spec-tools tests (if available)
echo ""
echo "[5/7] Running Python spec-tools tests..."

SPEC_TOOLS_PYTEST=""
if [ -f ".venv/bin/pytest" ] && [ -d ".venv/lib" ]; then
    SPEC_TOOLS_PYTEST=".venv/bin/pytest"
elif command -v pytest &>/dev/null && python3 -c "import spec_tools" 2>/dev/null; then
    SPEC_TOOLS_PYTEST="pytest"
fi

if [ -n "$SPEC_TOOLS_PYTEST" ]; then
    if $SPEC_TOOLS_PYTEST scripts/tests/ --tb=short -q 2>&1 | tee /tmp/morph_precommit_pytest.log; then
        echo ""
        echo "[5/7] Python spec-tools tests PASSED"
    else
        echo ""
        echo "[5/7] Python spec-tools tests FAILED"
        echo ""
        echo "Commit blocked. Fix the failing Python tests above."
        exit 1
    fi
else
    echo "[5/7] Python spec-tools not found (skipped)."
    echo "       To enable: pip install -e scripts/ in a virtual environment."
fi

# Step 6: Python linting and type-checking (if available)
echo ""
echo "[6/7] Running ruff lint and mypy type-check..."

LINT_PASS=true

# Prefer .venv/bin/ tools over system tools
RUFF_CMD=""
MYPY_CMD=""
if [ -f ".venv/bin/ruff" ]; then
    RUFF_CMD=".venv/bin/ruff"
elif command -v ruff &>/dev/null; then
    RUFF_CMD="ruff"
fi

if [ -f ".venv/bin/mypy" ]; then
    MYPY_CMD=".venv/bin/mypy"
elif command -v mypy &>/dev/null; then
    MYPY_CMD="mypy"
fi

if [ -n "$RUFF_CMD" ]; then
    if $RUFF_CMD check scripts/spec_tools/ 2>&1 | tee /tmp/morph_precommit_ruff.log; then
        echo "  ruff check PASSED"
    else
        echo "  ruff check FAILED"
        LINT_PASS=false
    fi

    if $RUFF_CMD format --check scripts/spec_tools/ 2>&1 | tee /tmp/morph_precommit_format.log; then
        echo "  ruff format PASSED"
    else
        echo "  ruff format FAILED -- run 'ruff format scripts/spec_tools/' to fix"
        LINT_PASS=false
    fi
else
    echo "  ruff not found (skipped)."
fi

if [ -n "$MYPY_CMD" ]; then
    if $MYPY_CMD scripts/spec_tools/ --ignore-missing-imports 2>&1 | tee /tmp/morph_precommit_mypy.log; then
        echo "  mypy PASSED"
    else
        echo "  mypy FAILED"
        LINT_PASS=false
    fi
else
    echo "  mypy not found (skipped)."
fi

if [ "$LINT_PASS" = false ]; then
    echo ""
    echo "[6/7] Lint/type-check FAILED. Commit blocked."
    exit 1
fi
echo "[6/7] All lint/type-check PASSED"

# Step 7: spec-tools checks on staged markdown files (if available)
echo ""
echo "[7/7] Running spec-tools checks on markdown files..."
SPEC_TOOLS_CMD=""
if [ -f ".venv/bin/spec-tools" ]; then
    SPEC_TOOLS_CMD=".venv/bin/spec-tools"
elif command -v spec-tools &>/dev/null; then
    SPEC_TOOLS_CMD="spec-tools"
fi

if [ -n "$SPEC_TOOLS_CMD" ]; then
    MD_FILES=$(git diff --cached --name-only --diff-filter=ACM '*.md' 2>/dev/null || true)
    if [ -n "$MD_FILES" ]; then
        LINT_OK=true
        for md_file in $MD_FILES; do
            if [ -f "$md_file" ]; then
                if ! $SPEC_TOOLS_CMD lint "$md_file" 2>&1; then
                    LINT_OK=false
                fi
            fi
        done
        if [ "$LINT_OK" = true ]; then
            echo "[7/7] spec-tools lint PASSED"
        else
            echo "[7/7] spec-tools lint FAILED (warnings only, commit allowed)"
        fi
    else
        echo "[7/7] No markdown files staged, skipping spec-tools."
    fi
else
    echo "[7/7] spec-tools not found (skipped)."
fi

echo ""
echo "========================================="
echo " Pre-commit checks PASSED"
echo "========================================="
echo ""
exit 0
