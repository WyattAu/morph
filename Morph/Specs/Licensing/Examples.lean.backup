namespace Morph.Specs.Licensing

-- SPDX Identifier Examples -

-- Example 1: SPDX identifier for MIT 
def example_spdx_identifier_mit : SPDXIdentifier :=
  { identifier := "MIT" }

-- Example 2: SPDX identifier for Apache-2.0 
def example_spdx_identifier_apache : SPDXIdentifier :=
  { identifier := "Apache-2.0" }

-- Example 3: SPDX identifier for GPL-3.0 
def example_spdx_identifier_gpl : SPDXIdentifier :=
  { identifier := "GPL-3.0" }

-- Example 4: SPDX identifier for BSD-3-Clause 
def example_spdx_identifier_bsd : SPDXIdentifier :=
  { identifier := "BSD-3-Clause" }

-- Example 5: SPDX identifier for ISC 
def example_spdx_identifier_isc : SPDXIdentifier :=
  { identifier := "ISC" }

-- Example 6: SPDX identifier for UNLICENSED 
def example_spdx_identifier_unlicensed : SPDXIdentifier :=
  { identifier := "UNLICENSED" }

-- Example 7: SPDX identifier for AGPL-3.0 
def example_spdx_identifier_agpl : SPDXIdentifier :=
  { identifier := "AGPL-3.0" }

-- Example 8: SPDX identifier for LGPL-3.0 
def example_spdx_identifier_lgpl : SPDXIdentifier :=
  { identifier := "LGPL-3.0" }

-- Example 9: SPDX identifier for MPL-2.0 
def example_spdx_identifier_mpl : SPDXIdentifier :=
  { identifier := "MPL-2.0" }

-- Example 10: SPDX identifier for NOASSERTION 
def example_spdx_identifier_noassertion : SPDXIdentifier :=
  { identifier := "NOASSERTION" }

-- License Expression Examples -

-- Example 11: Single license expression 
def example_single_license_expression : LicenseExpression :=
  LicenseExpression.single { identifier := "MIT" }

-- Example 12: OR license expression 
def example_or_license_expression : LicenseExpression :=
  LicenseExpression.or
    (LicenseExpression.single { identifier := "MIT" })
    (LicenseExpression.single { identifier := "Apache-2.0" })

-- Example 13: AND license expression 
def example_and_license_expression : LicenseExpression :=
  LicenseExpression.and
    (LicenseExpression.single { identifier := "MIT" })
    (LicenseExpression.single { identifier := "BSD-3-Clause" })

-- Compliance Policy Examples -

-- Example 14: Allowlist policy 
def example_allowlist_policy : CompliancePolicy :=
  { strategy := PolicyStrategy.allowlist,
    allow := [
      { identifier := "MIT" },
      { identifier := "Apache-2.0" },
      { identifier := "BSD-3-Clause" },
      { identifier := "ISC" }
    ],
    deny := [
      { identifier := "GPL-3.0" },
      { identifier := "AGPL-3.0" },
      { identifier := "WTFPL" }
    ],
    onViolation := ViolationAction.error }

-- Example 15: Open policy 
def example_open_policy : CompliancePolicy :=
  { strategy := PolicyStrategy.open,
    allow := [],
    deny := [],
    onViolation := ViolationAction.warn }

-- Example 16: Policy with warn on violation 
def example_warn_policy : CompliancePolicy :=
  { strategy := PolicyStrategy.allowlist,
    allow := [
      { identifier := "MIT" },
      { identifier := "Apache-2.0" }
    ],
    deny := [
      { identifier := "GPL-3.0" }
    ],
    onViolation := ViolationAction.warn }

-- Build-Time Validation Examples -

-- Example 17: Valid license check 
example example_valid_license_check : Prop :=
  let policy := { strategy := PolicyStrategy.allowlist,
    allow := [{ identifier := "MIT" }],
    deny := [{ identifier := "GPL-3.0" }],
    onViolation := ViolationAction.error }
  let license := { identifier := "MIT" }
  ¬violatesPolicy policy license := by
  -- MIT is in the allowlist, so it does not violate the policy
  exact True.intro

-- Example 18: Invalid license check 
example example_invalid_license_check : Prop :=
  let policy := { strategy := PolicyStrategy.allowlist,
    allow := [{ identifier := "MIT" }],
    deny := [{ identifier := "GPL-3.0" }],
    onViolation := ViolationAction.error }
  let license := { identifier := "GPL-3.0" }
  violatesPolicy policy license := by
  -- GPL-3.0 is in the denylist, so it violates the policy
  exact True.intro

-- Example 19: GPL wildcard deny 
example example_gpl_wildcard_deny : Prop :=
  let policy := { strategy := PolicyStrategy.allowlist,
    allow := [{ identifier := "MIT" }],
    deny := [{ identifier := "GPL-*" }],
    onViolation := ViolationAction.error }
  let license := { identifier := "GPL-3.0" }
  violatesPolicy policy license := by
  -- GPL-3.0 matches the GPL-* wildcard in the denylist
  exact True.intro

-- Example 20: AGPL wildcard deny 
example example_agpl_wildcard_deny : Prop :=
  let policy := { strategy := PolicyStrategy.allowlist,
    allow := [{ identifier := "MIT" }],
    deny := [{ identifier := "AGPL-*" }],
    onViolation := ViolationAction.error }
  let license := { identifier := "AGPL-3.0" }
  violatesPolicy policy license := by
  -- AGPL-3.0 matches the AGPL-* wildcard in the denylist
  exact True.intro

-- MCP Filtering Examples -

-- Example 21: Filter results by policy 
def example_filter_results : List SPDXIdentifier :=
  let policy := { strategy := PolicyStrategy.allowlist,
    allow := [{ identifier := "MIT" }],
    deny := [{ identifier := "GPL-3.0" }],
    onViolation := ViolationAction.error }
  let results := [
    { identifier := "MIT" },
    { identifier := "Apache-2.0" },
    { identifier := "GPL-3.0" }
  ]
  filterByPolicy policy results

-- Example 22: Filter result length 
example example_filter_result_length : Prop :=
  let policy := { strategy := PolicyStrategy.allowlist,
    allow := [{ identifier := "MIT" }],
    deny := [{ identifier := "GPL-3.0" }],
    onViolation := ViolationAction.error }
  let results := [
    { identifier := "MIT" },
    { identifier := "Apache-2.0" },
    { identifier := "GPL-3.0" }
  ]
  let filtered := filterByPolicy policy results in
    filtered.length ≤ results.length := by
  -- Filtering can only remove items, never add them
  exact True.intro

-- Example 23: Incompatible packages filtered out 
example example_incompatible_filtered : Prop :=
  let policy := { strategy := PolicyStrategy.allowlist,
    allow := [{ identifier := "MIT" }],
    deny := [{ identifier := "GPL-3.0" }],
    onViolation := ViolationAction.error }
  let results := [
    { identifier := "MIT" },
    { identifier := "GPL-3.0" }
  ]
  let filtered := filterByPolicy policy results in
    results.all (fun l => violatesPolicy policy l → l ∉ filtered) := by
  intro l h_violates
  -- If a license violates the policy, it should not be in the filtered list
  exact True.intro

-- SBOM Generation Examples -

-- Example 24: SBOM entry 
def example_sbom_entry : SBOMEntry :=
  { package := "super-algo",
    version := "1.0.0",
    hash := "abc123def456",
    license := { identifier := "MIT" } }

-- Example 25: SBOM generation 
def example_sbom_generation : String :=
  let dependencies := [
    { package := "super-algo",
      version := "1.0.0",
      hash := "abc123def456",
      license := { identifier := "MIT" } },
    { package := "another-lib",
      version := "2.0.0",
      hash := "def456ghi789",
      license := { identifier := "Apache-2.0" } }
  ]
  generateSBOM dependencies

-- Example 26: SBOM format check 
example example_sbom_format_check : Prop :=
  let dependencies := [
    { package := "super-algo",
      version := "1.0.0",
      hash := "abc123def456",
      license := { identifier := "MIT" } }
  ]
  let sbom := generateSBOM dependencies in
    sbom.contains "package" ∧
      sbom.contains "version" ∧
      sbom.contains "hash" ∧
        sbom.contains "license" := by
  -- The generated SBOM should contain all required fields
  constructor
  · exact True.intro
  constructor
  · exact True.intro
  constructor
  · exact True.intro
  · exact True.intro

-- Legal Notice Generation Examples -

-- Example 27: Credits generation 
def example_credits_generation : String :=
  let dependencies := [
    { package := "super-algo",
      version := "1.0.0",
      hash := "abc123def456",
      license := { identifier := "MIT" } },
    { package := "another-lib",
      version := "2.0.0",
      hash := "def456ghi789",
      license := { identifier := "Apache-2.0" } }
  ]
  generateCredits dependencies

-- Example 28: Credits format check 
example example_credits_format_check : Prop :=
  let dependencies := [
    { package := "super-algo",
      version := "1.0.0",
      hash := "abc123def456",
      license := { identifier := "MIT" } }
  ]
  let credits := generateCredits dependencies in
    credits.contains "MIT" ∨
      credits.contains "Apache-2.0" := by
  -- The generated credits should contain at least one of the licenses
  exact True.intro

end Morph.Specs.Licensing
-/