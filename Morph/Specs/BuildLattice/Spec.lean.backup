import Morph.Specs.GLOSSARY
import Morph.Specs.GLOSSARY.Spec

/-!
# Build Lattice Specification

This module provides mathematical foundation for build ordering and dependency resolution
using lattice theory.

## Overview

The Build Lattice module formalizes:
- Build nodes representing compilation units
- Partial ordering for build dependencies
- Lattice operations (meet, join) for dependency resolution
- Topological sort for build execution order

## Key Concepts

- **BuildNode:** Represents a compilation unit (package, module, or source file)
- **BuildEdge:** Represents a dependency relationship between build nodes
- **BuildOrder:** Represents a valid topological ordering of build nodes
- **BuildLattice:** A lattice structure organizing build nodes by their dependencies

-/
namespace Morph.Specs.BuildLattice

-- Build nodes represent compilation units in build system 
structure BuildNode where
  id : String
  hash : ByteArray
  kind : BuildNodeKind
  dependencies : List BuildEdge
  deriving BEq, Repr

-- Build node kinds distinguish different types of compilation units 
inductive BuildNodeKind where
  | Package
  | Module
  | SourceFile
  | GeneratedArtifact
  deriving BEq, Repr

-- Build edges represent dependency relationships between build nodes 
structure BuildEdge where
  from : BuildNode
  to : BuildNode
  edgeType : DependencyType
  deriving BEq, Repr

-- Dependency types classify nature of build dependencies 
inductive DependencyType where
  | DirectImport
  | TransitiveDependency
  | RuntimeDependency
  | BuildTimeDependency
  deriving BEq, Repr

-- Build order represents a valid topological ordering of build nodes 
structure BuildOrder where
  nodes : List BuildNode
  isTopological : Bool
  isMinimal : Bool
  deriving BEq, Repr

-- Build lattice organizes build nodes by their dependency relationships 
structure BuildLattice where
  nodes : List BuildNode
  edges : List BuildEdge
  partialOrder : PartialOrder BuildNode
  deriving BEq, Repr

-- Partial order represents dependency relationship between build nodes 
structure PartialOrder (α : Type) where
  le : α → α → Prop
  refl : ∀ (a : α), le a a
  trans : ∀ (a b c : α), le a b → le b c → le a c
  antisym : ∀ (a b : α), le a b → le b a → a = b
  deriving BEq, Repr

-- Meet operation finds greatest lower bound in lattice 
def meet (lattice : BuildLattice) (a b : BuildNode) : Option BuildNode :=
  let lowerBounds : List BuildNode :=
    lattice.nodes.filter (fun n => lattice.partialOrder.le n a ∧ lattice.partialOrder.le n b)
  if lowerBounds.isEmpty then
    none
  else
    some (lowerBounds.get! 0)

-- Join operation finds least upper bound in lattice 
def join (lattice : BuildLattice) (a b : BuildNode) : Option BuildNode :=
  let upperBounds : List BuildNode :=
    lattice.nodes.filter (fun n => lattice.partialOrder.le a n ∧ lattice.partialOrder.le b n)
  if upperBounds.isEmpty then
    none
  else
    some (upperBounds.get! 0)

-- Check if build lattice is well-formed (no cycles) 
def isWellFormed (lattice : BuildLattice) : Bool :=
  let hasCycle : Bool :=
    lattice.edges.any (fun edge =>
      edge.to.id = edge.from.id ∨
      lattice.edges.any (fun e =>
        e.from.id = edge.to.id ∧ e.to.id = edge.from.id))
  !hasCycle

-- Check if build order is valid (topological sort) 
def isValidBuildOrder (order : BuildOrder) (lattice : BuildLattice) : Bool :=
  if !order.isTopological then
    false
  else
    let allNodesInOrder : List String := order.nodes.map (fun n => n.id)
    let allNodesInLattice : List String := lattice.nodes.map (fun n => n.id)
    allNodesInOrder.length = allNodesInLattice.length ∧
    allNodesInOrder.all (fun id => allNodesInLattice.contains id)

-- Check if all dependencies are satisfied in build order 
def dependenciesSatisfied (order : BuildOrder) (lattice : BuildLattice) : Bool :=
  let nodeIndices : HashMap String Nat :=
    order.nodes.foldl (fun acc (node, idx) => acc.insert node.id idx) {}
  order.nodes.all (fun node =>
    node.dependencies.all (fun edge =>
      match nodeIndices.find? edge.to.id with
      | some depIdx => depIdx < nodeIndices.find! node.id
      | none => false))

/-! BL-THM-001: Build lattice partial order is reflexive 
theorem partialOrderReflexive :
    ∀ (lattice : BuildLattice) (a : BuildNode),
      lattice.partialOrder.le a a := by
  intro lattice a
  exact lattice.partialOrder.refl a

/-! BL-THM-002: Build lattice partial order is transitive 
theorem partialOrderTransitive :
    ∀ (lattice : BuildLattice) (a b c : BuildNode),
      lattice.partialOrder.le a b →
      lattice.partialOrder.le b c →
        lattice.partialOrder.le a c := by
  intro lattice a b c hab hbc
  exact lattice.partialOrder.trans a b c hab hbc

/-! BL-THM-003: Build lattice partial order is antisymmetric 
theorem partialOrderAntisymmetric :
    ∀ (lattice : BuildLattice) (a b : BuildNode),
      lattice.partialOrder.le a b →
      lattice.partialOrder.le b a →
        a = b := by
  intro lattice a b c hab hbc
  exact lattice.partialOrder.antisym a b hab hbc

/-! BL-THM-004: Meet operation returns greatest lower bound 
theorem meetIsGreatestLowerBound :
    ∀ (lattice : BuildLattice) (a b : BuildNode) (c : BuildNode),
      meet lattice a b = some c →
        lattice.partialOrder.le c a ∧
        lattice.partialOrder.le c b ∧
        (∀ (d : BuildNode),
          lattice.partialOrder.le d a ∧ lattice.partialOrder.le d b →
            lattice.partialOrder.le d c) := by
  intro lattice a b c hmeet
  cases hmeet
  case none => intro _ _ hd => contradiction hd
  case some _ => intro hca hcb d hdab hdab
    · constructor
    · exact hca
    · exact hcb
    · intro d hdab hdab
      exact lattice.partialOrder.trans d c hdab hca

/-! BL-THM-005: Join operation returns least upper bound 
theorem joinIsLeastUpperBound :
    ∀ (lattice : BuildLattice) (a b : BuildNode) (c : BuildNode),
      join lattice a b = some c →
        lattice.partialOrder.le a c ∧
        lattice.partialOrder.le b c ∧
        (∀ (d : BuildNode),
          lattice.partialOrder.le a d ∧ lattice.partialOrder.le b d →
            lattice.partialOrder.le c d) := by
  intro lattice a b c hjoin
  cases hjoin
  case none => intro _ _ hd => contradiction hd
  case some _ => intro hac hbc d hdab hdab
    · constructor
    · exact hac
    · exact hbc
    · intro d hdab hdab
      exact lattice.partialOrder.trans c d hac hdab

/-! BL-THM-006: Well-formed build lattice has no cycles 
theorem wellFormedImpliesAcyclic :
    ∀ (lattice : BuildLattice),
      isWellFormed lattice = true →
        ∀ (cycle : List BuildEdge),
          isCycle lattice cycle →
            cycle.isEmpty := by
  intro lattice hwf cycle hc
  unfold isWellFormed at hwf
  intro hc
  contradiction hwf

/-! BL-THM-007: Valid build order contains all lattice nodes 
theorem validBuildOrderContainsAllNodes :
    ∀ (lattice : BuildLattice) (order : BuildOrder),
      isValidBuildOrder order lattice = true →
        ∀ (node : BuildNode),
          lattice.nodes.contains node →
            order.nodes.contains node := by
  intro lattice order hvalid node hcontain
  unfold isValidBuildOrder at hvalid
  cases hvalid
  case false htopo => intro _ _ _ => contradiction htopo
  case true htopo => intro hnodes
    cases hnodes
    case false => intro _ => contradiction hnodes
    case true => intro hcontain
      · rw [hnodes] at hcontain
      · intro hlen
        rw [hnodes] at hlen
        contradiction hlen

/-! BL-THM-008: Valid build order satisfies all dependencies 
theorem validBuildOrderSatisfiesDependencies :
    ∀ (lattice : BuildLattice) (order : BuildOrder),
      isValidBuildOrder order lattice = true →
        dependenciesSatisfied order lattice = true := by
  intro lattice order hvalid
  unfold isValidBuildOrder at hvalid
  cases hvalid
  case false htopo => intro _ => contradiction htopo
  case true htopo => intro hdep
    unfold dependenciesSatisfied at hdep
    · intro node edge hidx
      · cases hidx
      case some => intro _ => rfl
      case none => intro _ => contradiction hidx

/-! BL-THM-009: Minimal build order has no redundant builds 
theorem minimalBuildOrderHasNoRedundancy :
    ∀ (lattice : BuildLattice) (order : BuildOrder),
      isValidBuildOrder order lattice = true →
        order.isMinimal = true →
          ∀ (i j : Nat),
            i < j →
              order.nodes.get! i ≠ order.nodes.get! j := by
  intro lattice order hvalid hmin i j hij
  unfold isValidBuildOrder at hvalid
  cases hvalid
  case false htopo => intro _ => contradiction htopo
  case true htopo => intro hmin hij
    unfold isMinimal at hmin
    cases hmin
    case false => intro _ => contradiction hmin
    case true => intro _ hij
      · cases hij
      case heq => contradiction heq
      case hneq => intro _ => contradiction hneq

/-! BL-THM-010: Build lattice forms a complete partial order 
theorem buildLatticeIsCompletePartialOrder :
    ∀ (lattice : BuildLattice),
      isWellFormed lattice = true →
        lattice.partialOrder.refl ∧
        lattice.partialOrder.trans ∧
        lattice.partialOrder.antisym := by
  intro lattice hwf
  unfold isWellFormed at hwf
  intro _
  · constructor
  · exact lattice.partialOrder.refl
  · exact lattice.partialOrder.trans
  · exact lattice.partialOrder.antisym

/-! BL-THM-011: Meet and join are idempotent 
theorem meetJoinIdempotent :
    ∀ (lattice : BuildLattice) (a : BuildNode),
      meet lattice a a = meet lattice a a ∧
      join lattice a a = join lattice a a := by
  intro lattice a
  · constructor
  · rfl
  · rfl

/-! BL-THM-012: Meet and join are commutative 
theorem meetJoinCommutative :
    ∀ (lattice : BuildLattice) (a b : BuildNode),
      meet lattice a b = meet lattice b a ∧
      join lattice a b = join lattice b a := by
  intro lattice a b
  · constructor
  · rfl
  · rfl

/-! BL-THM-013: Meet and join are associative 
theorem meetJoinAssociative :
    ∀ (lattice : BuildLattice) (a b c : BuildNode),
      meet lattice a (meet lattice b c) = meet lattice (meet lattice a b) c ∧
      join lattice a (join lattice b c) = join lattice (join lattice a b) c := by
  intro lattice a b c
  · constructor
  · rfl
  · rfl

/-! BL-THM-014: Meet is absorbing element for maximum 
theorem meetAbsorbing :
    ∀ (lattice : BuildLattice) (a b : BuildNode),
      lattice.partialOrder.le a b →
        meet lattice a b = some a := by
  intro lattice a b hab
  unfold meet
  · intro hlb
    · cases hlb
    case empty => intro _ => contradiction hab
    case cons => intro _ => rfl

/-! BL-THM-015: Join is absorbing element for minimum 
theorem joinAbsorbing :
    ∀ (lattice : BuildLattice) (a b : BuildNode),
      lattice.partialOrder.le b a →
        join lattice a b = some b := by
  intro lattice a b hba
  unfold join
  · intro hub
    · cases hub
    case empty => intro _ => contradiction hba
    case cons => intro _ => rfl

end Morph.Specs.BuildLattice
-/