namespace Morph.Specs.RegistryConsensus

open Morph.Core
open Morph.Syntax
open Morph.Memory

-- ## State Machine Replication Examples

### State Machine Replication

-- Example: Two replicas with the same log 
def example_replica1 : Replica :=
  { id := { id := 0 },
    state := { value := 42, hash := hash 42 },
    log := [{ id := 0, operation := "increment" }],
    commitIndex := 1 }

def example_replica2 : Replica :=
  { id := { id := 1 },
    state := { value := 42, hash := hash 42 },
    log := [{ id := 0, operation := "increment" }],
    commitIndex := 1 }

def example_replicas : List Replica :=
  [example_replica1, example_replica2]

example : spec_state_machine_replication example_replicas := by
  -- Proof: Both replicas have the same committed log
  intro r1 r2
  intro h1
  have h2 : r1.log.take r1.commitIndex = r2.log.take r2.commitIndex := by
    cases h1
  case intro h3 h4 =>
      -- Both replicas are in the list, so their states must be equal
      rfl
  exact h2

-- ## Multi-Paxos Examples

### Multi-Paxos Protocol

-- Example: A Multi-Paxos instance with two replicas 
def example_ballot : Ballot :=
  { number := 1 }

def example_command : Command :=
  { id := 0, operation := "increment" }

def example_proposal : Proposal :=
  { ballot := example_ballot, command := example_command }

def example_multi_paxos : MultiPaxos :=
  { replicas := [{ id := 0 }, { id := 1 }],
    proposals := [example_proposal],
    promises := [],
    accepts := [],
    chosen := [example_ballot] }

example : spec_multi_paxos_protocol example_multi_paxos := by
  -- Proof: Only one ballot is chosen
  intro b1 b2
  intro h1
  cases h1
  case intro h2 h3 =>
      -- Both ballots are in the chosen list
      have h4 : b1 = example_ballot := by
        -- Since example_multi_paxos.chosen = [example_ballot]
        -- and b1 ∈ example_multi_paxos.chosen by h2
        -- By definition of List membership, b1 must equal the only element
        cases h2
        case intro hb =>
          -- b1 is example_ballot by membership
          rfl
      have h5 : b2 = example_ballot := by
        -- Since example_multi_paxos.chosen = [example_ballot]
        -- and b2 ∈ example_multi_paxos.chosen by h3
        -- By definition of List membership, b2 must equal the only element
        cases h3
        case intro hb =>
          -- b2 is example_ballot by membership
          rfl
      left
      exact h4 ▸ h5

-- ## Raft Examples

### Raft Protocol

-- Example: A Raft cluster with three nodes 
def example_raft_term : RaftTerm :=
  { number := 1 }

def example_raft_node1 : RaftNode :=
  { id := { id := 0 },
    state := .leader,
    term := example_raft_term,
    log := [{ id := 0, operation := "increment" }],
    commitIndex := 1,
    votedFor := some { id := 0 } }

def example_raft_node2 : RaftNode :=
  { id := { id := 1 },
    state := .follower,
    term := example_raft_term,
    log := [{ id := 0, operation := "increment" }],
    commitIndex := 1,
    votedFor := some { id := 0 } }

def example_raft_node3 : RaftNode :=
  { id := { id := 2 },
    state := .follower,
    term := example_raft_term,
    log := [{ id := 0, operation := "increment" }],
    commitIndex := 1,
    votedFor := some { id := 0 } }

def example_raft_cluster : RaftCluster :=
  { nodes := [example_raft_node1, example_raft_node2, example_raft_node3],
    currentTerm := example_raft_term }

example : spec_raft_protocol example_raft_cluster := by
  -- Proof: Only one leader in term 1
  intro t
  have h1 : t.number = example_raft_term.number := by
    -- Since t is arbitrary, we need to show the property holds for any t
    -- For t = example_raft_term, we need to show filter length ≤ 1
    -- For t ≠ example_raft_term, the filter will return empty list (length 0)
    -- In both cases, length ≤ 1 holds
    cases (Classical.em (t.number = example_raft_term.number))
    case inl heq =>
      -- t.number = example_raft_term.number
      -- Filter returns nodes with matching term and leader state
      -- Only example_raft_node1 has state = .leader
      rfl
    case inr hne =>
      -- t.number ≠ example_raft_term.number
      -- Filter returns empty list (no nodes with matching term)
      -- Empty list has length 0, which is ≤ 1
      have h2 : example_raft_cluster.nodes.filter (fun n => n.term = t ∧ n.state = .leader) = [] := by
        -- No node has term = t since t ≠ example_raft_term
        -- Therefore filter returns empty list
        rfl
      rw [h2]
      exact Nat.zero_le_one
  have h2 : example_raft_cluster.nodes.filter (fun n => n.term = t ∧ n.state = .leader).length ≤ 1 := by
    -- From h1, we've shown the length is either 1 or 0
    -- Both are ≤ 1
    cases (Classical.em (t.number = example_raft_term.number))
    case inl heq =>
      -- When t matches example_raft_term, only example_raft_node1 is leader
      -- Filter returns [example_raft_node1], length = 1
      have h3 : example_raft_cluster.nodes.filter (fun n => n.term = t ∧ n.state = .leader) = [example_raft_node1] := by
        -- Only example_raft_node1 has state = .leader
        rfl
      rw [h3]
      rfl
    case inr hne =>
      -- When t doesn't match, filter returns empty list
      -- Empty list has length 0, which is ≤ 1
      have h3 : example_raft_cluster.nodes.filter (fun n => n.term = t ∧ n.state = .leader) = [] := by
        -- No node has term = t
        rfl
      rw [h3]
      exact Nat.zero_le_one
  exact h2

-- ## Merkle State Verification Examples

### Merkle State Verification

-- Example: A state with Merkle verification 
def example_state : State :=
  { value := 42, hash := hash 42 }

def example_merkle_tree : List (Hash × Hash) :=
  [(hash 42, hash 21), (hash 42, hash 21)]

def example_merkle_state : MerkleState :=
  { root := hash 42, tree := example_merkle_tree }

def example_state_with_merkle : StateWithMerkle :=
  { state := example_state, merkle := example_merkle_state }

example : example_state_with_merkle.verify = true := by
  -- Proof: The root hash matches the state hash
  rfl

example : spec_merkle_state_verification example_state_with_merkle
                                       example_state_with_merkle := by
  -- Proof: The state matches its Merkle tree
  intro h1 h2 h3
  rfl

-- ## Consensus Safety Examples

### Consensus Safety

-- Example: Consensus safety - all replicas agree on the committed state 
def example_consensus_safety_replicas : List Replica :=
  [ { id := { id := 0 },
      state := { value := 42, hash := hash 42 },
      log := [{ id := 0, operation := "increment" }],
      commitIndex := 1 },
    { id := { id := 1 },
      state := { value := 42, hash := hash 42 },
      log := [{ id := 0, operation := "increment" }],
      commitIndex := 1 } ]

example : ConsensusSafety example_consensus_safety_replicas := by
  -- Proof: All replicas have the same state
  intro r1 r2
  intro h1
  cases h1
  case intro h2 h3 =>
      -- Both replicas are in the list, so their states must be equal
      rfl

-- ## Consensus Liveness Examples

### Consensus Liveness

-- Example: Consensus liveness - all commands are eventually committed 
def example_consensus_liveness_replicas : List Replica :=
  [ { id := { id := 0 },
      state := { value := 42, hash := hash 42 },
      log := [{ id := 0, operation := "increment" },
               { id := 1, operation := "increment" }],
      commitIndex := 2 },
    { id := { id := 1 },
      state := { value := 42, hash := hash 42 },
      log := [{ id := 0, operation := "increment" },
               { id := 1, operation := "increment" }],
      commitIndex := 2 } ]

def example_consensus_liveness_commands : List Command :=
  [{ id := 0, operation := "increment" },
   { id := 1, operation := "increment" } ]

example : ConsensusLiveness example_consensus_liveness_replicas
                                 example_consensus_liveness_commands := by
  -- Proof: All commands are committed
  intro cmd
  intro h1
  cases h1
  case intro h2 h3 =>
      -- Command is in the list
      -- Both replicas have commitIndex = 2, so both commands are committed
      -- For cmd = example_consensus_liveness_commands.get! 0 (id = 0):
      --   - Both replicas have it at index 0, and 0 ≤ 2
      -- For cmd = example_consensus_liveness_commands.get! 1 (id = 1):
      --   - Both replicas have it at index 1, and 1 ≤ 2
      -- Therefore, there exists a replica and index for each command
      cases (Classical.em (cmd.id = 0))
      case inl hcmd0 =>
        -- Command has id = 0
        let r := example_consensus_liveness_replicas.get! 0
        have h2 : r.id = 0 ∧ r.log.get! 0 = cmd ∧ 0 ≤ 2 := by
          constructor
          -- r.id = 0 by definition
          rfl
          -- r.log.get! 0 = cmd by example definition
          rfl
          -- 0 ≤ 2 is trivial
          exact Nat.zero_le_two
        exists r, (fun _ => h2)
      case inr hcmd1 =>
        -- Command has id = 1
        have hcmd1 : cmd.id = 1 := by
          -- From hcmd1 (cmd.id ≠ 0) and cmd.id ∈ {0, 1}
          -- By excluded middle, cmd.id = 1
          cases h1
          case intro h0 h1 =>
            -- cmd is at index 0, so cmd.id = 0
            contradiction hcmd1
          case intro h1 h2 =>
            -- cmd is at index 1, so cmd.id = 1
            rfl
        let r := example_consensus_liveness_replicas.get! 0
        have h2 : r.id = 0 ∧ r.log.get! 1 = cmd ∧ 1 ≤ 2 := by
          constructor
          -- r.id = 0 by definition
          rfl
          -- r.log.get! 1 = cmd by example definition
          rfl
          -- 1 ≤ 2 is trivial
          exact Nat.one_le_two
        exists r, (fun _ => h2)

end Morph.Specs.RegistryConsensus
-/