import Morph.Core
import Morph.Syntax
import Morph.Specs.ScopingLambdaCalculus.Spec

namespace Morph.Specs.ScopingLambdaCalculus

/-!
## Scoping and Lambda Calculus Examples

This module contains concrete examples and test cases for
scoping and lambda calculus specification.


/-!
## Example 1: Environment Lookup

Demonstrates environment lookup.


-- Environment with variable bindings 
def example_env : Morph.Core.Env :=
  [("x", Morph.Core.Value.int 42), ("y", Morph.Core.Value.int 10)]

-- Lookup variable 
def example_lookup : Option Morph.Core.Value :=
  lookupEnv example_env "x"

-- Example: Verify lookup 
#eval example_lookup
-- Expected: some (int 42)

/-!
## Example 2: Free Variables

Demonstrates free variable computation.


-- Expression: x + y 
def example_expr1 : Morph.Syntax.Expr :=
  .binop .add (.var (Morph.Syntax.Id.mk "x")) (.var (Morph.Syntax.Id.mk "y"))

-- Free variables of x + y 
def example_free_vars1 : List String :=
  freeVars example_expr1

-- Example: Verify free variables 
#eval example_free_vars1
-- Expected: ["x", "y"]

-- Lambda expression: λx. x + y 
def example_expr2 : Morph.Syntax.Expr :=
  .lam [Morph.Syntax.Id.mk "x"]
    (.binop .add (.var (Morph.Syntax.Id.mk "x")) (.var (Morph.Syntax.Id.mk "y")))

-- Free variables of λx. x + y (y is free, x is bound) 
def example_free_vars2 : List String :=
  freeVars example_expr2

-- Example: Verify free variables 
#eval example_free_vars2
-- Expected: ["y"]

/-!
## Example 3: Bound Variables

Demonstrates bound variable computation.


-- Bound variables of λx. x + y 
def example_bound_vars : List String :=
  boundVars example_expr2

-- Example: Verify bound variables 
#eval example_bound_vars
-- Expected: ["x"]

/-!
## Example 4: Alpha Conversion

Demonstrates variable renaming to avoid capture.


-- Original lambda: λx. x + y 
def example_original : Morph.Syntax.Expr :=
  .lam [Morph.Syntax.Id.mk "x"]
    (.binop .add (.var (Morph.Syntax.Id.mk "x")) (.var (Morph.Syntax.Id.mk "y")))

-- Alpha convert with used variables ["x", "y"] 
def example_alpha : Morph.Syntax.Expr :=
  alphaConvert example_original ["x", "y"]

-- Example: Verify alpha conversion 
#eval example_alpha
-- Expected: λx0. x0 + y (x renamed to x0 to avoid capture)

/-!
## Example 5: Substitution

Demonstrates variable substitution.


-- Expression: x + y 
def example_expr3 : Morph.Syntax.Expr :=
  .binop .add (.var (Morph.Syntax.Id.mk "x")) (.var (Morph.Syntax.Id.mk "y")))

-- Substitute x with 42 
def example_subst : Morph.Syntax.Expr :=
  substitute example_expr3 "x" (.lit (Morph.Core.Value.int 42))

-- Example: Verify substitution 
#eval example_subst
-- Expected: 42 + y

/-!
## Example 6: Beta Reduction

Demonstrates lambda application and beta reduction.


-- Lambda: λx. x + 1 
def example_lambda : Morph.Syntax.Expr :=
  .lam [Morph.Syntax.Id.mk "x"]
    (.binop .add (.var (Morph.Syntax.Id.mk "x")) (.lit (Morph.Core.Value.int 1)))

-- Apply lambda to argument 5 
def example_app : Morph.Syntax.Expr :=
  .app example_lambda (.lit (Morph.Core.Value.int 5))

-- Single beta reduction step 
def example_beta_step : Option Morph.Syntax.Expr :=
  betaReduceStep example_app

-- Example: Verify beta reduction step 
#eval example_beta_step
-- Expected: some (5 + 1)

/-!
## Example 7: Weak Head Normal Form

Demonstrates weak head normal form computation.


-- Compute WHNF of (λx. x + 1) 5 
def example_whnf : Morph.Syntax.Expr :=
  whnf example_app

-- Example: Verify WHNF 
#eval example_whnf
-- Expected: 6 (after full reduction)

end Morph.Specs.ScopingLambdaCalculus
-/