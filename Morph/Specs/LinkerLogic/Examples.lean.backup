import Morph.Core
import Morph.Syntax
import Morph.Specs.LinkerLogic.Spec

namespace Morph.Specs.LinkerLogic

/-!
# Linker Logic Examples

This module contains concrete examples and test cases for the
linker logic, demonstrating symbol resolution, module dependency
management, and linking semantics.
-/

/-!
## Example 1: Symbol Table Operations

Demonstrates basic symbol table operations.


-- Create symbol table with symbols 
def example_symbol_table : SymbolTable :=
  let info1 : SymbolInfo := {name := "main", module := "Main", typ := Morph.Core.Typ.functionType [] Morph.Core.Typ.unitType, defined := true}
  let info2 : SymbolInfo := {name := "helper", module := "Main", typ := Morph.Core.Typ.functionType [Morph.Core.Typ.stringType] Morph.Core.Typ.unitType, defined := true}
  let info3 : SymbolInfo := {name := "data", module := "Data", typ := Morph.Core.Typ.pointerType, defined := true}
  emptySymbolTable
  |> addSymbol info1
  |> addSymbol info2
  |> addSymbol info3

-- Example: Lookup symbol 
def example_lookup : Option SymbolInfo :=
  lookupSymbol example_symbol_table "main"

-- Example: Check if symbol is defined 
def example_defined : Bool :=
  isSymbolDefined example_symbol_table "main"

/-!
## Example 2: Module Dependency Graph

Demonstrates module dependency graph operations.


-- Create module graph with dependencies 
def example_module_graph : ModuleGraph :=
  let mainInfo : ModuleInfo := {name := "Main", symbols := ["main", "helper", "data"], dependencies := [], linked := false}
  let dataInfo : ModuleInfo := {name := "Data", symbols := ["process", "read"], dependencies := ["Main"], linked := false}
  emptyModuleGraph
  |> addModule mainInfo
  |> addModule dataInfo

-- Example: Get module dependencies 
def example_dependencies : List String :=
  getModuleDependencies example_module_graph "Data"

-- Example: Check if module is linked 
def example_linked : Bool :=
  isModuleLinked example_module_graph "Main"

/-!
## Example 3: Linking Process

Demonstrates linking process.


-- Initial link state 
def example_link_state : LinkState :=
  initialLinkState

-- Add symbols to state 
def example_add_symbols : LinkState :=
  let info1 : SymbolInfo := {name := "main", module := "Main", typ := Morph.Core.Typ.functionType [] Morph.Core.Typ.unitType, defined := true}
  let info2 : SymbolInfo := {name := "helper", module := "Main", typ := Morph.Core.Typ.functionType [Morph.Core.Typ.stringType] Morph.Core.Typ.unitType, defined := true}
  example_link_state
  |> addSymbolToState info1
  |> addSymbolToState info2

-- Add module to state 
def example_add_module : LinkState :=
  let info : ModuleInfo := {name := "Data", symbols := ["process", "read"], dependencies := ["Main"], linked := false}
  example_add_symbols
  |> addModuleToState info

-- Mark module as linked 
def example_mark_linked : LinkState :=
  markModuleLinked example_add_symbols.moduleGraph "Main"

-- Example: Add link error 
def example_with_error : LinkState :=
  addLinkError example_add_symbols "Undefined symbol 'unknown'"

/-!
## Example 4: Correctness Verification

Demonstrates verification of correctness properties.


-- Verify symbol table is well-formed 
#eval example_symbol_table_well_formed
#eval example_symbol_table_well_formed

-- Verify no duplicate symbols 
#eval example_no_duplicates
#eval example_no_duplicates

-- Verify module graph is acyclic 
#eval example_module_graph_acyclic
#eval example_module_graph_acyclic

-- Verify initial state is valid 
#eval example_initial_state_valid
#eval example_initial_state_valid

/-!
## Example 5: Complete Linking Workflow

Demonstrates end-to-end linking workflow.


-- Complete linking example 
def example_complete_linking : LinkState :=
  let state1 := example_add_symbols
  let state2 := markModuleLinked state1
  let state3 := markModuleLinked state2
  state2

-- Example: Linking with errors 
def example_linking_with_errors : LinkState :=
  let state1 := example_add_symbols
  let state2 := addLinkError state1 "Undefined symbol 'unknown'"
  let state3 := addLinkError state2 "Undefined symbol 'unknown'"
  let state4 := addLinkError state2 "Undefined symbol 'unknown'"
  state4

end Morph.Specs.LinkerLogic
-/