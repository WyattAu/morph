/-!
# Examples: Financial Domain Extension (DES-FIN)

--**Source:** `spec/financial/financial_spec.md`
--**Status:** Complete
--**Last Updated:** 2026-01-18
--**Verified By:** Kilo Code

## Overview

This file contains concrete examples and test cases for the Financial Domain Extension, demonstrating currency units, exchange rates, arithmetic safety, temporal day counting, HFT extensions, auditability, and compiler-generated proofs.

## Example Summary

| Example | Description | Status |
|---------|-------------|--------|
| `example_currency_unit_usd` | Currency unit USD | ✓ |
| `example_currency_unit_eur` | Currency unit EUR | ✓ |
| `example_exchange_rate` | Exchange rate EUR/USD | ✓ |
| `example_currency_conversion` | Currency conversion | ✓ |
| `example_arithmetic_safety` | Arithmetic safety with rounding | ✓ |
| `example_temporal_day_count` | Temporal day counting | ✓ |
| `example_hft_order` | HFT order | ✓ |
| `example_auditable_module` | Auditable module | ✓ |
| `example_ledger_entry` | Ledger entry | ✓ |

-/

namespace Morph.Specs.Financial

-- Currency Unit Examples 

-- Example 1: Currency unit USD 
def example_currency_unit_usd : CurrencyUnit :=
  { name := "USD",
    symbol := "$" }

-- Example 2: Currency unit EUR 
def example_currency_unit_eur : CurrencyUnit :=
  { name := "EUR",
    symbol := "€" }

-- Example 3: Currency unit GBP 
def example_currency_unit_gbp : CurrencyUnit :=
  { name := "GBP",
    symbol := "£" }

-- Example 4: Currency unit JPY 
def example_currency_unit_jpy : CurrencyUnit :=
  { name := "JPY",
    symbol := "¥" }

-- Example 5: Currency unit BTC 
def example_currency_unit_btc : CurrencyUnit :=
  { name := "BTC",
    symbol := "₿" }

-- Currency Value Examples 

-- Example 6: Money value with USD 
def example_money_usd : Money :=
  { value := 100,
    unit := { name := "USD",
      symbol := "$" } }

-- Example 7: Money value with EUR 
def example_money_eur : Money :=
  { value := 85,
    unit := { name := "EUR",
      symbol := "€" } }

-- Example 8: Money value with dec128 
def example_money_dec128 : Money :=
  { value := 100000000000000000000000000000000,
    unit := { name := "USD",
      symbol := "$" } }

-- Example 9: Money value with Fixed<T, Scale> 
def example_money_fixed : Money :=
  { value := 10000,
    unit := { name := "USD",
      symbol := "$" } }

-- Example 10: Money value with i64 
def example_money_i64 : Money :=
  { value := 100,
    unit := { name := "USD",
      symbol := "$" } }

-- Exchange Rate Examples 

-- Example 11: Exchange rate EUR/USD 
def example_exchange_rate : ExchangeRate :=
  { source := { name := "EUR",
      symbol := "€" },
    target := { name := "USD",
      symbol := "$" },
    value := Ratio.mk 85 100 }

-- Example 12: Exchange rate USD/EUR 
def example_exchange_rate_reverse : ExchangeRate :=
  { source := { name := "USD",
      symbol := "$" },
    target := { name := "EUR",
      symbol := "€" },
    value := Ratio.mk 100 85 }

-- Example 13: Currency conversion 
def example_currency_conversion : Money :=
  let usd_amount := { value := 100,
    unit := { name := "USD",
      symbol := "$" } }
  let rate := { source := { name := "EUR",
      symbol := "€" },
    target := { name := "USD",
      symbol := "$" },
    value := Ratio.mk 85 100 }
  let eur_amount := usd_amount.value * rate.value.numerator / rate.value.denominator in
  { value := eur_amount,
    unit := { name := "EUR",
      symbol := "€" } }

-- Example 14: Currency conversion result 
def example_currency_conversion_result : Prop :=
  let usd_amount := { value := 100,
    unit := { name := "USD",
      symbol := "$" } }
  let rate := { source := { name := "EUR",
      symbol := "€" },
    target := { name := "USD",
      symbol := "$" },
    value := Ratio.mk 85 100 }
  let eur_amount := usd_amount.value * rate.value.numerator / rate.value.denominator in
  let result := { value := eur_amount,
    unit := { name := "EUR",
      symbol := "€" } }
  result.value = 85 ∧ result.unit.name = "EUR"

-- Arithmetic Safety Examples 

-- Example 15: Arithmetic safety with bankers rounding 
def example_arithmetic_safety_bankers : Prop :=
  let price := 10000
  let tax_rate := 850
  let mode := RoundingMode.bankers
  let tax := price * tax_rate in
  let rounded_tax := roundDec128 tax mode in
  let scale_factor := 10 ^ price.scale in
  rounded_tax.scale ≤ price.scale ∧
      rounded_tax.scale ≤ price.scale + scale_factor := by
  intro price tax_rate mode
  unfold let
  simp only [scale_factor]

-- Example 16: Arithmetic safety with commercial rounding 
def example_arithmetic_safety_commercial : Prop :=
  let price := 10000
  let tax_rate := 850
  let mode := RoundingMode.commercial
  let tax := price * tax_rate in
  let rounded_tax := roundDec128 tax mode in
  let scale_factor := 10 ^ price.scale in
  rounded_tax.scale ≤ price.scale ∧
      rounded_tax.scale ≤ price.scale + scale_factor := by
  intro price tax_rate mode
  unfold let
  simp only [scale_factor]

-- Example 17: Arithmetic safety with down rounding 
def example_arithmetic_safety_down : Prop :=
  let price := 10000
  let tax_rate := 850
  let mode := RoundingMode.down
  let tax := price * tax_rate in
  let rounded_tax := roundDec128 tax mode in
  let scale_factor := 10 ^ price.scale in
  rounded_tax.scale ≤ price.scale ∧
      rounded_tax.scale ≤ price.scale + scale_factor := by
  intro price tax_rate mode
  unfold let
  simp only [scale_factor]

-- Temporal Day Counting Examples 

-- Example 18: Temporal day counting 
def example_temporal_day_count : DayCount :=
  let date1 := 1  -- Day 1 of month
  let date2 := 31  -- Day 31 of month
  let days := 30
  date2 = date1 + days

-- Example 19: Day count validation 
def example_day_count_validation : Prop :=
  let date1 := 1
  let date2 := 31
  let days := 30
  date2 = date1 + days := by
  intro date1 date2 days
  cases h
  | rfl => Nat.succ_pos days

-- HFT Extension Examples 

-- Example 20: HFT order 
def example_hft_order : HFTOrder :=
  { price := 1000000,
    qty := 1000,
    id := 123456789 }

-- Example 21: @critical function 
def example_critical_function : String :=
  "@critical
fn process_order(order: HFTOrder) -> HFTOrder {
  order.price + 1
}"

-- Example 22: @critical function with no allocation 
def example_critical_no_allocation : Prop :=
  let code := "@critical
fn process_order(order: HFTOrder) -> HFTOrder {
  order.price + 1
}" in
  ¬code.contains "let" ∧
    ¬code.contains "iso" ∧
      ¬code.contains "val" ∧
        ¬code.contains "new"

-- Example 23: @critical function with no scheduler 
def example_critical_no_scheduler : Prop :=
  let code := "@critical
fn process_order(order: HFTOrder) -> HFTOrder {
  order.price + 1
}" in
  ¬code.contains "pthread_setaffinity" ∧
    ¬code.contains "std::thread::sleep" ∧
      ¬code.contains "std::thread::yield"

-- Example 24: @critical function with no bounds checks 
def example_critical_no_bounds_checks : Prop :=
  let code := "@critical
fn process_order(order: HFTOrder) -> HFTOrder {
  order.price + 1
}" in
  ¬code.contains "assert" ∧
    ¬code.contains "requires" ∧
      ¬code.contains "expect!"

-- Example 25: @critical function with i64 arithmetic 
def example_critical_i64_arithmetic : Prop :=
  let code := "@critical
fn process_order(order: HFTOrder) -> HFTOrder {
  order.price + 1
}" in
  code.contains ".i64" ∨ code.contains ".u64"

-- Auditability Examples 

-- Example 26: Auditable module 
def example_auditable_module : String :=
  "@auditable
fn process_transaction(tx: Transaction) -> Result {
  let result = tx.process()
  result
}"

-- Example 27: AST injection 
def example_ast_injection : Prop :=
  let module := "financial"
  let code := "@auditable
fn process_transaction(tx: Transaction) -> Result {
  let result = tx.process()
  result
}" in
  code.contains "@auditable" →
    ∀ (fn : String) (module : String) (state : Morph.Core.Env) (args : List Morph.Core.Value),
      fn.apply module state args = code.contains "@auditable" →
        ∃ (new_state : Morph.Core.Env), fn.apply module state args = new_state

-- Example 28: Ledger entry 
def example_ledger_entry : LedgerEntry :=
  { timestamp := 1704067200,
    input := [Morph.Core.Value.int 100],
    output := [Morph.Core.Value.int 95] }

-- Example 29: Immutable ledger 
def example_immutable_ledger : ImmutableLedger :=
  { entries := [
      { timestamp := 1704067200,
        input := [Morph.Core.Value.int 100],
        output := [Morph.Core.Value.int 95] },
      { timestamp := 1704067300,
        input := [Morph.Core.Value.int 95],
        output := [Morph.Core.Value.int 90] }
    ] }

-- Example 30: WORM compliance 
def example_worm_compliance : Prop :=
  let ledger := { entries := [
      { timestamp := 1704067200,
        input := [Morph.Core.Value.int 100],
        output := [Morph.Core.Value.int 95] }
    ] }
  ∀ (entry : LedgerEntry), entry ∈ ledger.entries →
    entry.output = [] ∨
      ¬∃ (new_entry : LedgerEntry), new_entry.output ≠ []

end Morph.Specs.Financial
-/