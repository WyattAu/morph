# EditorConfig for Morph Project
# Enforces UTF-8 encoding and consistent formatting for all files

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# Lean files - enforce UTF-8 with BOM for proper Unicode character support
[*.lean]
charset = utf-8-bom
indent_style = space
indent_size = 2

# Markdown files
[*.md]
charset = utf-8
indent_style = space
indent_size = 2

# JSON files
[*.json]
charset = utf-8
indent_style = space
indent_size = 2

# TOML files
[*.toml]
charset = utf-8
indent_style = space
indent_size = 2

# YAML files
[*.{yml,yaml}]
charset = utf-8
indent_style = space
indent_size = 2
